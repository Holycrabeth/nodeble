# NODEBLE Iron Condor Strategy — Moderate Template

mode: dry_run

watchlist:
  - SPY
  - QQQ
  - IWM
  - AAPL
  - MSFT

selection:
  min_iv_rank: 0.30
  min_iv_rv_ratio: 0
  put_delta_min: 0.10
  put_delta_max: 0.20
  call_delta_min: 0.10
  call_delta_max: 0.20
  min_open_interest: 100
  max_spread_pct: 0.10
  min_credit_pct: 0.20
  dte_min: 21
  dte_max: 45
  dte_ideal: 30
  prefer_monthly: true
  earnings_blackout_days: 7
  cooldown_days: 3
  max_new_positions_per_run: 2
  price_guard_pct: 0.03
  delta_range: [0.10, 0.20]
  max_risk_per_trade: 3500

management:
  max_risk_per_trade: 3500
  profit_take_pct: 0.50
  stop_loss_pct: 2.0
  close_before_dte: 3

execution:
  allow_degradation: false
  fill_timeout_sec: 30

sizing:
  spread_width_rules:
    - {max_price: 200, width: 5}
    - {max_price: 500, width: 10}
    - {max_price: 999999, width: 15}

# Health monitoring (optional)
# Create a check at https://healthchecks.io and paste the ping URL here
# health_check_url: "https://hc-ping.com/YOUR-UUID-HERE"
