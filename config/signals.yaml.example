# NODEBLE Signal Configuration — Voting thresholds and indicator evolution

voting:
  implemented_indicators: 20
  min_active_ratio: 0.35
  min_active_categories: 3
  deadband: 0.06
  buy_threshold: 0.58
  strong_buy_threshold: 0.70
  sell_threshold: 0.58
  strong_sell_threshold: 0.70

indicator_evolution:
  adaptive_rsi:
    enabled: true
    lookback: 252
    pctile_low: 10.0
    pctile_high: 90.0
    floor_low: 20.0
    ceil_high: 80.0
